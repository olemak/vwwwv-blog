# vwwwv-blog — local environment.
#
# Copy this file to `.env` and fill in. `.env` is gitignored.
# Two purposes here, kept side-by-side so the values are easy to find:
#
#   1. CLAUDE CODE / PUBLISH SKILL — credentials the AI editor uses to
#      reach the deployed Worker over HTTPS. The skill (skill/SKILL.md)
#      reads PUBLISH_URL and PUBLISH_TOKEN from this file.
#
#   2. WRANGLER LOCAL DEV — variables wrangler injects when running
#      `wrangler dev` against a local Worker. Wrangler actually reads
#      `apps/site/.dev.vars`, NOT this file; we keep the same names here
#      so `cp .env apps/site/.dev.vars` is a one-liner if you want them
#      mirrored.

# ─── (1) Publish skill — Claude Code reads this ──────────────────────
# The deployed Worker URL. Update once you bind blog.vwwwv.org as a
# custom domain.
CF_PUBLISH_URL=https://vwwwv-blog.<your-account>.workers.dev

# ─── (2) Worker auth — used by the skill AND mirrored to .dev.vars ───
# Cloudflare Access service-token Client ID. Anything works until you
# put real Access in front of /api/*.
CF_ACCESS_CLIENT_ID=

# Bearer secret for the publish API. The skill sends it as
# `Authorization: Bearer $CF_ACCESS_CLIENT_SECRET`. Same value the
# Worker holds (set with `wrangler secret put CF_ACCESS_CLIENT_SECRET`
# from apps/site/). One value, two homes.
CF_ACCESS_CLIENT_SECRET=

# Signing secret for the flag-override preview cookie. Generate with:
#   openssl rand -base64 48
FLAG_COOKIE_SECRET=

# Optional: image generation provider key (used by the publish skill
# when AI-image generation is wired up — v1.5).
IMAGE_GEN_API_KEY=
